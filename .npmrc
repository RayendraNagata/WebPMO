# Allow packages with stale peerDependency declarations to install without error.
# Specifically: gantt-task-react@0.3.9 declares react@^18 but works correctly on
# React 19 (uses only standard hooks: useState, useEffect, useRef, useMemo —
# no removed APIs). When gantt-task-react releases a version declaring react@^19
# compatibility, this line can be removed.
legacy-peer-deps=true
